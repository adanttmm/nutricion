ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Xiaomi S400 (báscula de composición corporal) ─────────────────────────────
# Cuenta Xiaomi Home (la misma del teléfono)
XIAOMI_EMAIL=tu@correo.com
XIAOMI_PASSWORD=tu_contrasena

# Región del servidor Xiaomi (ru=Europa, us, sg, cn, de, i2)
XIAOMI_REGION=ru

# Modelo de báscula (S400 EU: ms104 / S400 CN: ms103)
XIAOMI_SCALE=yunmai.scales.ms104

# Nombre del perfil en la app Xiaomi Home (solo si la báscula tiene varios usuarios)
# Déjalo vacío para usar el perfil principal de la cuenta
XIAOMI_USER_ATM=
XIAOMI_USER_IOB=
