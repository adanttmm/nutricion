ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Xiaomi S400 (báscula de composición corporal) ─────────────────────────────
# Cuenta Xiaomi Home (la misma del teléfono)
XIAOMI_EMAIL=tu@correo.com
XIAOMI_PASSWORD=tu_contrasena

# Región del servidor Xiaomi (ru=Europa, us, sg, cn, de, i2)
XIAOMI_REGION=ru

# ID del dispositivo Android del teléfono con Mi Fitness instalado.
# Esto permite que Xiaomi reconozca el script como el mismo teléfono confiable
# y omita la verificación de dispositivo nuevo.
#
# Cómo obtenerlo (una sola vez):
#   Opción A — con cable USB (Developer Options + USB Debugging activados):
#     adb shell settings get secure android_id
#   Opción B — sin cable:
#     Instala la app "Device ID" de Play Store → copia el valor "Android ID"
#
XIAOMI_DEVICE_ID=

# Modelo de báscula (S400 EU: ms104 / S400 CN: ms103)
XIAOMI_SCALE=yunmai.scales.ms104

# Nombre del perfil en la app Xiaomi Home (solo si la báscula tiene varios usuarios)
# Déjalo vacío para usar el perfil principal de la cuenta
XIAOMI_USER_ATM=
XIAOMI_USER_IOB=
